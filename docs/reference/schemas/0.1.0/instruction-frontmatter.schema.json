{
  "$id": "https://raw.githubusercontent.com/outfitter-dev/skillset/main/docs/reference/schemas/0.1.0/instruction-frontmatter.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "claude": {
      "anyOf": [
        {
          "type": "boolean"
        },
        {
          "type": "object"
        }
      ]
    },
    "codex": {
      "anyOf": [
        {
          "type": "boolean"
        },
        {
          "not": {
            "properties": {
              "mode": {
                "const": "symlink"
              }
            },
            "required": [
              "mode"
            ]
          },
          "type": "object"
        }
      ]
    },
    "cursor": {
      "anyOf": [
        {
          "type": "boolean"
        },
        {
          "type": "object"
        }
      ]
    },
    "description": {
      "minLength": 1,
      "type": "string"
    },
    "dialect": {
      "enum": [
        "claude"
      ],
      "type": "string"
    },
    "metadata": {
      "additionalProperties": true,
      "properties": {
        "generated": {
          "type": "string"
        },
        "version": {
          "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|[A-Za-z-][0-9A-Za-z-]*)(?:\\.(?:0|[1-9]\\d*|[A-Za-z-][0-9A-Za-z-]*))*))?(?:\\+([0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*))?$",
          "type": "string"
        }
      },
      "type": "object"
    },
    "name": {
      "minLength": 1,
      "type": "string"
    },
    "paths": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "type": "array"
    },
    "skillset": {
      "additionalProperties": false,
      "properties": {
        "author": {
          "type": [
            "object",
            "string"
          ]
        },
        "category": {
          "type": "string"
        },
        "description": {
          "minLength": 1,
          "type": "string"
        },
        "homepage": {
          "type": "string"
        },
        "keywords": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "license": {
          "enum": [
            "Apache-2.0",
            "BSD-2-Clause",
            "BSD-3-Clause",
            "ISC",
            "MIT",
            "MPL-2.0",
            "none"
          ],
          "type": "string"
        },
        "manifest": {
          "type": "object"
        },
        "marketplace": {
          "type": "object"
        },
        "name": {
          "minLength": 1,
          "type": "string"
        },
        "origin": {
          "additionalProperties": false,
          "dependentRequired": {
            "ref": [
              "repo"
            ],
            "repo": [
              "ref"
            ]
          },
          "properties": {
            "path": {
              "minLength": 1,
              "type": "string"
            },
            "ref": {
              "minLength": 1,
              "type": "string"
            },
            "repo": {
              "minLength": 1,
              "type": "string"
            }
          },
          "required": [
            "path"
          ],
          "type": "object"
        },
        "outputs": {
          "type": "object"
        },
        "owner": {
          "type": "object"
        },
        "preprocess": {
          "type": "boolean"
        },
        "presentation": {
          "type": "object"
        },
        "repository": {
          "type": "string"
        },
        "schema": {
          "const": 1,
          "type": "integer"
        },
        "strict": {
          "type": "boolean"
        },
        "summary": {
          "minLength": 1,
          "type": "string"
        },
        "title": {
          "minLength": 1,
          "type": "string"
        },
        "version": {
          "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|[A-Za-z-][0-9A-Za-z-]*)(?:\\.(?:0|[1-9]\\d*|[A-Za-z-][0-9A-Za-z-]*))*))?(?:\\+([0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*))?$",
          "type": "string"
        }
      },
      "type": "object"
    },
    "summary": {
      "minLength": 1,
      "type": "string"
    },
    "supports": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "items": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "additionalProperties": false,
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "onMismatch": {
                    "enum": [
                      "error",
                      "warn"
                    ],
                    "type": "string"
                  },
                  "range": {
                    "type": "string"
                  },
                  "source": {
                    "type": "string"
                  }
                },
                "type": "object"
              }
            ]
          },
          "type": "array"
        },
        {
          "additionalProperties": false,
          "properties": {
            "packages": {
              "items": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "additionalProperties": false,
                    "properties": {
                      "name": {
                        "type": "string"
                      },
                      "onMismatch": {
                        "enum": [
                          "error",
                          "warn"
                        ],
                        "type": "string"
                      },
                      "range": {
                        "type": "string"
                      },
                      "source": {
                        "type": "string"
                      }
                    },
                    "type": "object"
                  }
                ]
              },
              "type": "array"
            }
          },
          "required": [
            "packages"
          ],
          "type": "object"
        }
      ]
    },
    "title": {
      "minLength": 1,
      "type": "string"
    },
    "version": {
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|[A-Za-z-][0-9A-Za-z-]*)(?:\\.(?:0|[1-9]\\d*|[A-Za-z-][0-9A-Za-z-]*))*))?(?:\\+([0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*))?$",
      "type": "string"
    }
  },
  "title": "Instruction Frontmatter",
  "type": "object"
}
