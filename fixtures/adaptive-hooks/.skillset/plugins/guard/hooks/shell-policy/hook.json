{
  "name": "shell-policy",
  "description": "Checks shell commands before they run.",
  "events": ["PreToolUse"],
  "context": {
    "strategy": "toolkit",
    "env": ["provider", "hook.event", "session.id"]
  },
  "run": {
    "env": {
      "SKILLSET_FIXTURE_HOOK": "shell-policy"
    },
    "script": "./check.sh"
  }
}
