{
  "PreToolUse": [
    {
      "matcher": "^Bash$",
      "hooks": [
        {
          "type": "command",
          "command": "./scripts/check.sh",
          "timeout": 30
        }
      ]
    }
  ],
  "SessionStart": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "./scripts/check.sh"
        }
      ]
    }
  ]
}
