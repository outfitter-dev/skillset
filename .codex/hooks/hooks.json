{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bun ./apps/skillset/src/cli.ts hooks run post-tool-use"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run test:sandbox -- bun ./apps/skillset/src/cli.ts hooks run stop"
          }
        ]
      }
    ]
  }
}
