{
  "name": "skillset",
  "version": "0.1.0",
  "description": "Source-first compiler for Claude and Codex agent loadouts.",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/outfitter-dev/skillset.git"
  },
  "bugs": {
    "url": "https://github.com/outfitter-dev/skillset/issues"
  },
  "homepage": "https://github.com/outfitter-dev/skillset#readme",
  "keywords": [
    "agents",
    "claude",
    "codex",
    "plugins",
    "skills"
  ],
  "bin": {
    "skillset": "./src/cli.ts"
  },
  "scripts": {
    "build": "bun run typecheck",
    "check": "bun run typecheck && bun test && bun run skillset:lint && bun run skillset:check && git diff --check",
    "skillset:build": "bun ./src/cli.ts build --root . --yes",
    "skillset:check": "bun ./src/cli.ts check --root .",
    "skillset:lint": "bun ./src/cli.ts lint --root .",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/bun": "^1.2.15",
    "typescript": "^5.8.3"
  }
}
