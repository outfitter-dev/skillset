{
  "name": "skillset",
  "version": "0.1.0-beta.5",
  "description": "Source-first compiler for Claude and Codex agent loadouts.",
  "keywords": [
    "agents",
    "claude",
    "codex",
    "plugins",
    "skills"
  ],
  "homepage": "https://github.com/outfitter-dev/skillset#readme",
  "bugs": {
    "url": "https://github.com/outfitter-dev/skillset/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/outfitter-dev/skillset.git"
  },
  "bin": {
    "create-skillset": "dist/create.js",
    "skillset": "dist/cli.js"
  },
  "files": [
    "dist/*.js",
    "docs/",
    "README.md"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public",
    "tag": "beta"
  },
  "scripts": {
    "build": "bun run typecheck && bun run build:npm",
    "build:npm": "bun scripts/build-package.ts",
    "check": "bun run build && bun test && bun run format:guard && bun run format:check && bun run skillset:lint && bun run skillset:check && git diff --check",
    "check:pr": "bun run check && bun run check:workflows && bun run skillset:ci:report",
    "check:workflows": "if command -v actionlint >/dev/null 2>&1; then actionlint .github/workflows/*.yml; else echo 'skillset: actionlint not installed; skipping workflow lint'; fi",
    "format:check": "bunx ultracite check .",
    "format:file": "bun scripts/format-staged.ts",
    "format:fix": "bunx ultracite fix .",
    "format:guard": "if git grep -nE \"(\\\\./)?node_modules/\\\\.bin/ultra[c]ite\" -- ':!bun.lock'; then echo 'Direct node_modules/.bin formatter invocation found'; exit 1; fi",
    "hooks:install": "lefthook install",
    "hooks:pre-commit": "lefthook run pre-commit --force",
    "hooks:pre-push": "lefthook run pre-push --force",
    "lint": "oxlint .",
    "prepack": "tsc --noEmit && bun scripts/build-package.ts",
    "skillset:build": "bun ./src/cli.ts build --root . --yes",
    "skillset:check": "bun ./src/cli.ts check --root .",
    "skillset:ci": "bun ./src/cli.ts ci --root .",
    "skillset:ci:report": "bun ./src/cli.ts ci --root . --since origin/main --report .skillset/build/skillset-ci-report.md",
    "skillset:lint": "bun ./src/cli.ts lint --root .",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/bun": "^1.2.15",
    "lefthook": "^2.1.1",
    "oxfmt": "0.47.0",
    "oxlint": "1.62.0",
    "typescript": "^5.8.3",
    "ultracite": "7.6.2"
  },
  "engines": {
    "bun": ">=1.3.14"
  },
  "packageManager": "bun@1.3.14",
  "trustedDependencies": [
    "lefthook",
    "oxfmt",
    "oxlint"
  ]
}
